# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter — gateway de LLM para generar dossiers
# Crear API key en https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Modelo a usar. Ejemplos:
#   openai/gpt-5:online           (búsqueda web nativa, sufijo :online)
#   anthropic/claude-sonnet-4.5   (calidad alta, sin web search)
#   anthropic/claude-haiku-4.5    (rápido y económico)
OPENROUTER_MODEL=openai/gpt-5:online
# Opcionales (OpenRouter los usa para ranking público y headers HTTP)
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_NAME=AI Clinics — Lab10
